{
  "name": "booking-os",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace @booking/web",
    "dev:desktop": "npm run dev --workspace @booking/desktop",
    "build:core": "npm run build --workspace @booking/core",
    "build:web": "npm run build --workspace @booking/web",
    "build:desktop": "npm run build --workspace @booking/desktop",
    "build": "npm run build:core && npm run build:web && npm run build:desktop",
    "typecheck": "npm run typecheck --workspace @booking/core && npm run typecheck --workspace @booking/web && npm run typecheck --workspace @booking/desktop",
    "test": "npm run test --workspace @booking/core",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
